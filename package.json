{
  "name": "mister-hope-portfolio",
  "version": "0.0.0",
  "private": true,
  "author": {
    "name": "Mister-Hope"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Mister-Hope/portfolio-template.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "clean": "rimraf dist",
    "dev": "vite",
    "lint": "oxlint --fix --deny-warnings --report-unused-disable-directives && oxfmt",
    "lint:check": "oxlint --deny-warnings --report-unused-disable-directives && oxfmt --check",
    "preview": "vite preview"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@mr-hope/tsconfig": "0.0.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.1.1",
    "nano-staged": "1.0.2",
    "oxc-config-hope": "0.3.6",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "oxlint-tsgolint": "0.23.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "unrun": "^0.3.0",
    "vite": "^8.0.11"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --deny-warnings --report-unused-disable-directives"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.0.9",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^22.18.0 || >=24.0.0",
      "onFail": "error"
    }
  },
  "packageManager": "pnpm@11.0.9"
}
